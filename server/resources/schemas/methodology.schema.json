{
  "$ref": "#/definitions/MethodologyDefinition",
  "definitions": {
    "MethodologyDefinition": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "methodology": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+"
        },
        "enabled": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "gates": {
          "type": "object",
          "properties": {
            "include": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "exclude": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "methodologyGates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string"
              },
              "methodologyArea": {
                "type": "string"
              },
              "priority": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"]
              },
              "validationCriteria": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "criteria": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "severity": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low"]
              }
            },
            "required": ["id", "name"],
            "additionalProperties": false
          }
        },
        "phasesFile": {
          "type": "string"
        },
        "judgePromptFile": {
          "type": "string"
        },
        "systemPromptGuidance": {
          "type": "string"
        },
        "toolDescriptions": {
          "type": "object",
          "additionalProperties": {}
        },
        "templateSuggestions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "section": {
                "type": "string",
                "enum": ["system", "user"]
              },
              "type": {
                "type": "string",
                "enum": ["addition", "structure", "modification"]
              },
              "description": {
                "type": "string"
              },
              "content": {
                "type": "string"
              },
              "methodologyJustification": {
                "type": "string"
              },
              "impact": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              }
            },
            "required": ["section", "type"],
            "additionalProperties": false
          }
        }
      },
      "required": ["id", "name", "methodology", "version", "enabled"],
      "additionalProperties": true
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Methodology Definition",
  "description": "Schema for methodology.yaml — defines a methodology framework with gates, guidance, and tool overlays."
}
